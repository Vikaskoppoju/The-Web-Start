# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://thewebstart.in
NEXT_PUBLIC_WHATSAPP_NUMBER=+91XXXXXXXXXX
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/thewebstart/discovery

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=your_32_byte_hex_secret_here

# ── Database (Turso) ──────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@thewebstart.in
RESEND_TO_EMAIL=info@thewebstart.in

# ── Razorpay Payment Gateway ──────────────────────────────────────────────────
# Get credentials from https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) for development, live keys (rzp_live_*) for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here
