# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://thewebstart.in
NEXT_PUBLIC_WHATSAPP_NUMBER=+919XXXXXXXXX
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/thewebstart/discovery
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev   # Cloudflare R2 public URL (optional)

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=your_256_bit_random_secret_here

# ── Database (Turso) ──────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://thewebstart-db-yourname.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── Resend (Email Notifications) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@thewebstart.in
RESEND_TO_EMAIL=info@thewebstart.in
